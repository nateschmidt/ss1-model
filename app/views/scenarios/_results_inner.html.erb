<div>
  <%# ═══ PORTFOLIO SUMMARY ═══ %>
  <section class="mb-10">
    <div class="flex items-center gap-3 mb-5">
      <div class="w-1 h-5 bg-accent rounded-full"></div>
      <h2 class="section-label text-silver tracking-widest">Portfolio Return Profile</h2>
      <span class="text-xs text-steel ml-2"><%= @result[:num_simulations].to_s.reverse.gsub(/(\d{3})(?=\d)/, '\1,').reverse %> simulations &middot; <%= @result[:risk_level].to_s.capitalize %> risk</span>
    </div>

    <% sr = @result[:avg_stakeholder_returns] %>
    <div class="grid grid-cols-2 md:grid-cols-5 gap-4 mb-4">
      <div class="bg-charcoal border border-slate-mid/60 rounded-lg p-4">
        <span class="section-label block mb-1">Fund Size</span>
        <span class="text-xl text-white font-semibold" style="font-family: var(--font-data);"><%= format_money(@result[:fund_size]) %></span>
      </div>
      <div class="bg-charcoal border border-slate-mid/60 rounded-lg p-4">
        <span class="section-label block mb-1">Launched / Exited / Failed</span>
        <span class="text-xl font-semibold" style="font-family: var(--font-data);">
          <span class="text-white"><%= @result[:avg_launched] %></span><span class="text-steel">/</span><span class="text-signal-green"><%= @result[:avg_exited] %></span><span class="text-steel">/</span><span class="text-signal-red"><%= @result[:avg_failed] %></span>
        </span>
      </div>
      <div class="bg-charcoal border border-slate-mid/60 rounded-lg p-4">
        <span class="section-label block mb-1">Avg. Fund TVPI</span>
        <span class="text-xl text-accent font-semibold" style="font-family: var(--font-data);"><%= format_multiple(@result[:avg_tvpi]) %></span>
      </div>
      <div class="bg-charcoal border border-slate-mid/60 rounded-lg p-4">
        <span class="section-label block mb-1">Avg. SS1 LLC Return</span>
        <span class="text-xl text-accent font-semibold" style="font-family: var(--font-data);"><%= format_money(sr[:ss1]) %></span>
      </div>
      <div class="bg-charcoal border border-slate-mid/60 rounded-lg p-4">
        <span class="section-label block mb-1">Avg. Net Profit / (Loss)</span>
        <% net = sr[:ss1] - @result[:fund_size] %>
        <span class="text-xl font-semibold <%= net >= 0 ? 'text-signal-green' : 'text-signal-red' %>" style="font-family: var(--font-data);"><%= net >= 0 ? '+' : '' %><%= format_money(net) %></span>
      </div>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
      <div class="bg-charcoal border border-slate-mid/60 rounded-lg p-4">
        <span class="section-label block mb-1">Avg. Alloy Partners Return</span>
        <span class="text-lg text-accent font-semibold" style="font-family: var(--font-data);"><%= format_money(sr[:alloy]) %></span>
        <p class="text-xs text-steel mt-1">Common stock proceeds per simulation</p>
      </div>
      <div class="bg-charcoal border border-slate-mid/60 rounded-lg p-4">
        <span class="section-label block mb-1">Avg. Founders Return</span>
        <span class="text-lg text-ice font-semibold" style="font-family: var(--font-data);"><%= format_money(sr[:founders]) %></span>
        <p class="text-xs text-steel mt-1">Option pool proceeds per simulation</p>
      </div>
      <div class="bg-charcoal border border-slate-mid/60 rounded-lg p-4">
        <span class="section-label block mb-1">Avg. Consortium &amp; Advisory</span>
        <span class="text-lg text-signal-blue font-semibold" style="font-family: var(--font-data);"><%= format_money(sr[:consortium]) %></span>
        <p class="text-xs text-steel mt-1">Pooled common + advisory per simulation</p>
      </div>
      <div class="bg-charcoal border border-slate-mid/60 rounded-lg p-4">
        <span class="section-label block mb-1">Avg. Follow-on Investors</span>
        <span class="text-lg text-signal-green font-semibold" style="font-family: var(--font-data);"><%= format_money(sr[:follow_on]) %></span>
        <p class="text-xs text-steel mt-1">Seed: <%= format_money(sr[:seed]) %> &middot; A: <%= format_money(sr[:series_a]) %> &middot; B: <%= format_money(sr[:series_b]) %></p>
      </div>
    </div>

    <%# Percentile table %>
    <div class="bg-charcoal border border-slate-mid/60 rounded-lg overflow-hidden">
      <table class="w-full">
        <thead>
          <tr class="border-b border-slate-mid/60">
            <th class="text-left px-4 py-3 section-label">Percentile</th>
            <th class="text-right px-4 py-3 section-label">TVPI</th>
            <th class="text-right px-4 py-3 section-label">Total Returned</th>
            <th class="text-right px-4 py-3 section-label">Net Profit</th>
            <th class="text-center px-4 py-3 section-label">Launched</th>
            <th class="text-center px-4 py-3 section-label">Exits</th>
            <th class="text-center px-4 py-3 section-label">Failures</th>
          </tr>
        </thead>
        <tbody>
          <% labels = { p10: "Downside (10th)", p25: "Conservative (25th)", p50: "Median (50th)", p75: "Upside (75th)", p90: "Best Case (90th)" } %>
          <% @result[:percentiles].each do |key, data| %>
            <% highlight = key == :p50 %>
            <tr class="<%= highlight ? 'bg-accent/5 border-b border-accent/20' : 'border-b border-slate-mid/20' %> hover:bg-slate-deep/40 transition-colors">
              <td class="px-4 py-2.5 text-sm <%= highlight ? 'text-accent font-medium' : 'text-silver' %>"><%= labels[key] %></td>
              <td class="px-4 py-2.5 text-right data-cell <%= highlight ? 'text-accent font-semibold' : 'text-ice' %>"><%= format_multiple(data[:tvpi]) %></td>
              <td class="px-4 py-2.5 text-right data-cell text-ice"><%= format_money(data[:total_returned]) %></td>
              <td class="px-4 py-2.5 text-right data-cell">
                <% net = data[:total_returned] - @result[:fund_size] %>
                <span class="<%= net >= 0 ? 'text-signal-green' : 'text-signal-red' %>"><%= net >= 0 ? '+' : '' %><%= format_money(net) %></span>
              </td>
              <td class="px-4 py-2.5 text-center data-cell text-ice"><%= data[:companies_launched] %></td>
              <td class="px-4 py-2.5 text-center data-cell text-ice"><%= data[:companies_exited] %></td>
              <td class="px-4 py-2.5 text-center data-cell text-ice"><%= data[:companies_failed] %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>

  <%# ═══ MEDIAN SIMULATION DETAIL ═══ %>
  <% med = @result[:median_simulation] %>
  <section class="mb-10">
    <div class="flex items-center gap-3 mb-5">
      <div class="w-1 h-5 bg-accent rounded-full"></div>
      <h2 class="section-label text-silver tracking-widest">Median Simulation Detail</h2>
      <span class="text-xs text-steel ml-2"><%= format_multiple(med[:tvpi]) %> TVPI &middot; <%= med[:companies_launched] %> launched &middot; <%= med[:companies_exited] %> exits &middot; <%= med[:companies_failed] %> failures</span>
    </div>

    <div class="bg-charcoal border border-slate-mid/60 rounded-lg p-4 mb-6">
      <div class="flex items-center justify-between mb-3">
        <span class="section-label text-silver">Fund Drawdown</span>
        <span class="data-cell text-ash">Deployed: <%= format_money(med[:total_deployed]) %> of <%= format_money(@result[:fund_size]) %></span>
      </div>
      <div class="w-full bg-slate-deep rounded-full h-3 overflow-hidden">
        <% deployed_pct = (med[:total_deployed] / @result[:fund_size] * 100).clamp(0, 100) %>
        <div class="h-3 rounded-full bg-accent/60" style="width: <%= deployed_pct %>%"></div>
      </div>
      <div class="flex justify-between mt-1.5">
        <span class="text-xs text-steel">$0</span>
        <span class="text-xs text-steel"><%= format_money(@result[:fund_size]) %></span>
      </div>
    </div>

    <div class="space-y-4">
      <% med[:companies].each do |company| %>
        <div class="bg-charcoal border border-slate-mid/60 rounded-lg overflow-hidden">
          <div class="flex items-center justify-between px-5 py-3 border-b border-slate-mid/30">
            <div class="flex items-center gap-4">
              <span class="text-white font-medium text-sm">Company <%= company[:number] %></span>
              <span class="text-xs px-2 py-0.5 rounded border <%= outcome_badge_bg(company[:outcome]) %>"><%= company[:outcome].to_s.capitalize %></span>
              <span class="text-xs text-steel"><%= stage_label(company[:stage]) %></span>
            </div>
            <div class="flex items-center gap-6">
              <div class="text-right"><span class="section-label block">Deployed</span><span class="data-cell text-ice"><%= format_money(company[:capital_deployed]) %></span></div>
              <div class="text-right"><span class="section-label block">Exit Value</span><span class="data-cell <%= company[:exit_value] > 0 ? 'text-signal-green' : 'text-steel' %>"><%= company[:exit_value] > 0 ? format_money(company[:exit_value]) : '—' %></span></div>
              <div class="text-right"><span class="section-label block">Fund Return</span><span class="data-cell <%= company[:fund_return] > 0 ? 'text-accent' : 'text-steel' %>"><%= company[:fund_return] > 0 ? format_money(company[:fund_return]) : '—' %></span></div>
              <div class="text-right"><span class="section-label block">Fund Balance</span><span class="data-cell text-silver"><%= format_money(company[:fund_remaining]) %></span></div>
            </div>
          </div>
          <% if company[:rounds].any? || (company[:waterfall] && company[:waterfall].any?) %>
            <div class="px-5 py-3 flex gap-6">
              <% if company[:rounds].any? %>
                <div class="flex-1">
                  <span class="section-label block mb-2">Funding Rounds</span>
                  <div class="flex gap-3">
                    <% company[:rounds].each do |round| %>
                      <div class="bg-slate-deep/50 rounded px-3 py-2 text-xs">
                        <span class="text-silver font-medium"><%= round[:name] %></span>
                        <div class="text-ash mt-0.5"><%= format_money(round[:amount]) %> &middot; <%= "%.0f" % round[:dilution_pct] %>% dilution</div>
                      </div>
                    <% end %>
                  </div>
                </div>
              <% end %>
              <% if company[:cap_table] %>
                <div class="flex-1">
                  <span class="section-label block mb-2">Ownership at Exit</span>
                  <% active = company[:cap_table].reject { |_, v| v[:type] == :pool } %>
                  <% total_pct = active.values.sum { |v| v[:pct] } %>
                  <div class="grid grid-cols-2 gap-x-4 gap-y-1">
                    <% [:series_b, :series_a, :seed, :ss1, :founders, :alloy, :consortium, :advisory].each do |key| %>
                      <% entry = active[key] %>
                      <% next unless entry && entry[:pct] > 0 %>
                      <% effective_pct = total_pct > 0 ? (entry[:pct] / total_pct * 100) : 0 %>
                      <span class="text-xs text-ash">
                        <%= waterfall_keys_label(key) %>
                        <% if key == :founders && company[:founder_pool_pct] %>
                          <span class="text-accent-dim">(<%= "%.0f" % company[:founder_pool_pct] %>% / <%= "%.0f" % @vars_pool %>%)</span>
                        <% end %>
                      </span>
                      <span class="text-xs text-right data-cell <%= key == :ss1 ? 'text-accent font-medium' : 'text-ice' %>"><%= "%.1f" % effective_pct %>%</span>
                    <% end %>
                  </div>
                </div>
              <% end %>
              <% if company[:waterfall] && company[:waterfall].any? && company[:exit_value] > 0 %>
                <div class="flex-1">
                  <span class="section-label block mb-2">Exit Waterfall</span>
                  <div class="grid grid-cols-2 gap-x-4 gap-y-1">
                    <% [:series_b, :series_a, :seed, :ss1, :founders, :alloy, :consortium, :advisory].each do |key| %>
                      <% val = company[:waterfall][key] %>
                      <% next unless val && val > 0 %>
                      <span class="text-xs text-ash"><%= waterfall_keys_label(key) %></span>
                      <span class="text-xs text-right data-cell <%= key == :ss1 ? 'text-accent font-medium' : 'text-ice' %>"><%= format_money(val) %></span>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </section>

  <section class="mb-6">
    <div class="bg-slate-deep border border-slate-mid/60 rounded-lg p-5">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        <div><span class="section-label block mb-1">Total Deployed</span><span class="text-lg text-white font-semibold" style="font-family: var(--font-data);"><%= format_money(med[:total_deployed]) %></span></div>
        <div><span class="section-label block mb-1">Total Returned to Fund</span><span class="text-lg text-accent font-semibold" style="font-family: var(--font-data);"><%= format_money(med[:total_returned]) %></span></div>
        <div><span class="section-label block mb-1">Net Profit / (Loss)</span><% net = med[:total_returned] - @result[:fund_size] %><span class="text-lg font-semibold <%= net >= 0 ? 'text-signal-green' : 'text-signal-red' %>" style="font-family: var(--font-data);"><%= net >= 0 ? '+' : '' %><%= format_money(net) %></span></div>
        <div><span class="section-label block mb-1">TVPI (Median)</span><span class="text-lg text-white font-semibold" style="font-family: var(--font-data);"><%= format_multiple(med[:tvpi]) %></span></div>
      </div>
    </div>
  </section>
</div>
