<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) || "SS1 Financial Model — Alloy Partners" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&family=JetBrains+Mono:wght@400;500;600&family=Playfair+Display:wght@400;500;600;700&display=swap" rel="stylesheet">

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-midnight text-ice antialiased min-h-screen flex flex-col" style="font-family: var(--font-body);">
    <%# ═══ HEADER ═══ %>
    <header class="border-b border-slate-mid/50 bg-charcoal/80 backdrop-blur-sm sticky top-0 z-50">
      <div class="max-w-[1440px] mx-auto px-6 py-4 flex items-center justify-between">
        <div class="flex items-center gap-5">
          <%# Monogram mark %>
          <div class="w-10 h-10 rounded bg-accent flex items-center justify-center flex-shrink-0">
            <span class="text-midnight font-bold text-sm" style="font-family: var(--font-display);">SS1</span>
          </div>
          <div>
            <h1 class="text-xl font-semibold tracking-tight text-white" style="font-family: var(--font-display);">
              Sports Studio One
            </h1>
            <p class="text-xs text-ash tracking-wide mt-0.5">
              Managed by <span class="text-accent font-medium">Alloy Partners</span>
            </p>
          </div>
        </div>
        <div class="flex items-center gap-4">
          <% nav_items = [["Cap Table", root_path], ["Scenarios", scenarios_path], ["Deployment", deployment_path]] %>
          <nav class="flex items-center gap-1">
            <% nav_items.each do |label, path| %>
              <% active = request.path == path %>
              <%= link_to label, path,
                    class: "px-3 py-1.5 rounded text-xs font-medium tracking-wide transition-colors #{active ? 'bg-accent/15 text-accent' : 'text-steel hover:text-silver'}" %>
            <% end %>
          </nav>
          <div class="w-px h-5 bg-slate-mid"></div>
          <span class="data-cell text-ash"><%= Time.current.strftime("%B %Y") %></span>
          <div class="w-px h-5 bg-slate-mid"></div>
          <div data-controller="theme">
            <button data-action="click->theme#toggle"
              class="w-8 h-8 rounded-md border border-slate-mid/60 flex items-center justify-center text-ash hover:text-accent hover:border-accent/60 transition-colors"
              aria-label="Toggle light/dark mode">
              <%# Sun icon — shown in dark mode, click to go light %>
              <svg data-theme-target="sunIcon" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="5" />
                <line x1="12" y1="1" x2="12" y2="3" />
                <line x1="12" y1="21" x2="12" y2="23" />
                <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
                <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
                <line x1="1" y1="12" x2="3" y2="12" />
                <line x1="21" y1="12" x2="23" y2="12" />
                <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
                <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
              </svg>
              <%# Moon icon — shown in light mode, click to go dark %>
              <svg data-theme-target="moonIcon" class="w-4 h-4 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
              </svg>
            </button>
          </div>
        </div>
      </div>
    </header>

    <%# ═══ MAIN ═══ %>
    <main class="flex-1 max-w-[1440px] w-full mx-auto px-6 py-8">
      <%= yield %>
    </main>

    <%# ═══ FOOTER ═══ %>
    <footer class="border-t border-slate-mid/30 mt-auto">
      <div class="max-w-[1440px] mx-auto px-6 py-4 flex items-center justify-between">
        <span class="text-xs text-steel">&copy; 2026 Alloy Partners</span>
        <span class="text-xs text-steel/50">SS1 Financial Model v1.0</span>
      </div>
    </footer>
  </body>
</html>
